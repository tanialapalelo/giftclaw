# Required — Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# Required — Google Gemini API
GEMINI_API_KEY="your-gemini-api-key"

# Required — Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# Required — Sentry (error monitoring)
SENTRY_AUTH_TOKEN="your-sentry-auth-token"

# Optional — Public app URL (used for SEO metadata/OG images)
# Set to your actual domain in production
NEXT_PUBLIC_APP_URL="https://giftclaw.vercel.app"
