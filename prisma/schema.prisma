// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Friend {
  id          String    @id @default(uuid()) @db.Uuid
  shareToken  String    @unique @default(uuid()) @map("share_token") @db.Uuid
  name        String
  interests   String[]
  hobbies     String[]
  dislikes    String[]
  budgetMin   Int?      @map("budget_min")
  budgetMax   Int?      @map("budget_max")
  notes       String?
  theme       String    @default("soft")
  validUntil  DateTime? @map("valid_until")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  giftSuggestions GiftSuggestion[]
  gameResults     GameResult[]

  @@map("friends")
}

model GiftSuggestion {
  id           String   @id @default(uuid()) @db.Uuid
  friendId     String   @map("friend_id") @db.Uuid
  suggestions  Json
  modelVersion String   @map("model_version")
  createdAt    DateTime @default(now()) @map("created_at")

  friend Friend @relation(fields: [friendId], references: [id], onDelete: Cascade)

  @@map("gift_suggestions")
}

model GameResult {
  id           String   @id @default(uuid()) @db.Uuid
  friendId     String   @map("friend_id") @db.Uuid
  sessionId    String   @map("session_id") @db.Uuid
  grabIndex    Int      @map("grab_index")
  giftSnapshot Json     @map("gift_snapshot")
  createdAt    DateTime @default(now()) @map("created_at")

  friend Friend @relation(fields: [friendId], references: [id], onDelete: Cascade)

  @@map("game_results")
}
